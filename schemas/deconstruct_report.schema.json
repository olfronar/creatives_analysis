{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deconstruct_report.schema.json",
  "title": "Deconstruct Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["video_id", "creative_signal_only", "scores", "drop_off_hypotheses"],
  "properties": {
    "video_id": { "type": "string", "minLength": 1 },
    "creative_signal_only": { "const": true },
    "scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "score", "evidence", "confidence"],
        "properties": {
          "dimension": { "type": "string", "minLength": 1 },
          "score": { "type": "integer", "minimum": 0, "maximum": 3 },
          "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "confidence": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "drop_off_hypotheses": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
