{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "validation_result.schema.json",
  "title": "Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["target", "valid", "checks"],
  "properties": {
    "target": { "type": "string", "minLength": 1 },
    "valid": { "type": "boolean" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "notes"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["pass", "fail", "warn"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
